# IMESSAGE - Environment example

# Backend (create backend/.env or set these in your environment)
# Required
MONGO_URI=your_mongo_connection_string_here

# Optional (defaults shown in app)
PORT=3000
FRONTEND_URL=http://localhost:5173

# Optional - ImageKit (media uploads). If empty, media upload will be disabled.
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key_here

# Optional - Clerk webhook verification (if you use Clerk webhooks)
CLERK_WEBHOOK_SIGNING_SECRET=your_clerk_webhook_signing_secret_here


# Frontend (Vite)
# Create a file at frontend/.env.local or set these in your environment.
# Example:
# VITE_CLERK_PUBLISHABLE_KEY=pk_your_clerk_publishable_key
# VITE_API_BASE_URL=http://localhost:3000/api

# Note:
# - Do NOT commit real secrets to the repository. This file is intended as a template.
# - For production, use a secret manager or environment variables in your deployment platform.
